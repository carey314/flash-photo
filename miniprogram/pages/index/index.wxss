/* 首页样式 */
.page {
  padding-bottom: 120rpx;
}

/* Hero区域 */
.hero-section {
  margin: 20rpx 30rpx 0;
}

.hero-bg {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 50%, #2C6AA0 100%);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.hero-bg::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 30rpx;
}

.hero-price {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.price-highlight {
  font-size: 52rpx;
  font-weight: 800;
  color: #FFD700;
}

.price-original {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  text-decoration: line-through;
}

/* 快速操作 */
.quick-actions {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 30rpx;
  padding: 30rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  background: #F8FAFD;
  transition: all 0.2s;
}

.action-btn:active {
  background: #EBF3FB;
  transform: scale(0.97);
}

.main-action {
  background: linear-gradient(135deg, #EBF3FB, #D6E8F7);
  border: 2rpx solid #4A90D9;
}

.action-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #999;
}

/* 热门规格 */
.section {
  margin: 0 30rpx 20rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #4A90D9;
}

.specs-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.spec-item {
  width: calc(25% - 15rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.spec-preview {
  width: 120rpx;
  height: 160rpx;
  border-radius: 8rpx;
  border: 2rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.spec-size {
  font-size: 20rpx;
  color: #666;
}

.spec-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 4rpx;
}

/* 功能特色 */
.features {
  margin: 0 30rpx 20rpx;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.feature-icon {
  font-size: 44rpx;
  width: 60rpx;
  text-align: center;
}

.feature-info {
  flex: 1;
}

.feature-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 用户评价 */
.reviews {
  margin: 0 30rpx 20rpx;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.review-item {
  padding: 20rpx;
  background: #F8FAFD;
  border-radius: 12rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.review-name {
  font-size: 24rpx;
  color: #999;
}

.review-stars {
  font-size: 22rpx;
}

.review-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}

/* 免费提示 */
.free-tip {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(74, 144, 217, 0.95);
  color: #fff;
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.4);
  z-index: 10;
}
