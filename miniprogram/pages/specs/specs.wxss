/* 规格选择页 */
.page {
  padding-bottom: 180rpx;
}

/* 照片预览 */
.preview-section {
  margin: 20rpx 30rpx;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  height: 300rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.preview-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  padding: 20rpx 30rpx;
}

.preview-tip {
  color: #fff;
  font-size: 24rpx;
}

/* 背景色选择 */
.section {
  margin: 20rpx 30rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.bg-colors {
  display: flex;
  gap: 30rpx;
}

.bg-color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bg-color-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #E0E0E0;
  transition: all 0.2s;
}

.bg-color-item.active .bg-color-circle {
  border-color: #4A90D9;
  box-shadow: 0 0 0 4rpx rgba(74, 144, 217, 0.3);
}

.bg-color-name {
  font-size: 22rpx;
  color: #666;
}

/* 分类 tabs */
.category-tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
  -webkit-overflow-scrolling: touch;
}

.category-tab {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F5F5;
  flex-shrink: 0;
}

.category-tab.active {
  background: #4A90D9;
  color: #fff;
}

/* 规格列表 */
.specs-list {
  display: flex;
  flex-direction: column;
}

.spec-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
  transition: background 0.2s;
}

.spec-row:last-child {
  border-bottom: none;
}

.spec-row.active {
  background: #F0F7FF;
  border-radius: 12rpx;
}

.spec-row-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.spec-row-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.spec-row-desc {
  font-size: 24rpx;
  color: #999;
}

.spec-row-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.radio-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D0D0D0;
  transition: all 0.2s;
}

.radio-circle.checked {
  border-color: #4A90D9;
  background: #4A90D9;
  box-shadow: inset 0 0 0 6rpx #fff;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.bottom-info {
  display: flex;
  flex-direction: column;
}

.bottom-spec {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.bottom-price {
  font-size: 32rpx;
  color: #FF6B00;
  font-weight: 700;
}

.bottom-btn {
  flex-shrink: 0;
  padding: 20rpx 48rpx !important;
  font-size: 30rpx !important;
}
