/* 拍照页 */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000;
}

.camera-view {
  flex: 1;
  width: 100%;
  position: relative;
}

.guide-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.guide-frame {
  width: 360rpx;
  height: 480rpx;
  border: 4rpx dashed rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 40rpx;
}

.guide-head {
  width: 160rpx;
  height: 200rpx;
  border: 3rpx dashed rgba(255, 255, 255, 0.4);
  border-radius: 80rpx 80rpx 60rpx 60rpx;
}

.guide-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-top: 24rpx;
}

.controls {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 40rpx 60rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(0, 0, 0, 0.8);
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.control-icon {
  font-size: 48rpx;
}

.control-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.shutter-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-btn:active {
  opacity: 0.7;
}

.shutter-inner {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #fff;
}
