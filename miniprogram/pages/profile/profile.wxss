/* 个人中心 */
.page {
  padding: 0 30rpx 60rpx;
}

/* 用户信息 */
.user-section {
  padding-top: 40rpx;
  margin-bottom: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #4A90D9, #2C6AA0);
  border-radius: 20rpx;
  color: #fff;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.user-vip {
  display: block;
  font-size: 24rpx;
  color: #FFD700;
  margin-top: 4rpx;
}

.user-free {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.login-btn {
  background: rgba(255, 255, 255, 0.2) !important;
  color: #fff !important;
  border: 1rpx solid rgba(255, 255, 255, 0.5) !important;
  font-size: 26rpx !important;
  padding: 12rpx 30rpx !important;
  border-radius: 30rpx !important;
  line-height: 1.5 !important;
}

/* VIP 卡片 */
.vip-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFF8E1, #FFE082) !important;
  border: 1rpx solid #FFCA28;
}

.vip-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.vip-icon {
  font-size: 48rpx;
}

.vip-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #795548;
}

.vip-desc {
  display: block;
  font-size: 22rpx;
  color: #A1887F;
}

.vip-price {
  display: flex;
  align-items: baseline;
}

.vip-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #E65100;
}

.vip-period {
  font-size: 22rpx;
  color: #BF360C;
}

/* 统计 */
.stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A90D9;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E0E0E0;
}

/* 功能列表 */
.menu-list {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 44rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}
