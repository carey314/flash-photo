/* 结果页 */
.page {
  padding: 20rpx 30rpx;
  padding-bottom: 60rpx;
}

/* 预览区 */
.result-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.preview-card {
  width: 360rpx;
  height: 504rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-photo {
  width: 100%;
  height: 100%;
}

.preview-info {
  margin-top: 20rpx;
  text-align: center;
}

.spec-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.bg-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 排版选项 */
.layout-section {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.layout-options {
  display: flex;
  gap: 30rpx;
  justify-content: center;
}

.layout-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.layout-item.active {
  border-color: #4A90D9;
  background: #F0F7FF;
}

.layout-item text {
  font-size: 24rpx;
  color: #666;
}

.layout-thumb {
  width: 120rpx;
  height: 90rpx;
  border-radius: 8rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 8rpx;
}

.mini-photo {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 2rpx;
}

.single-thumb .mini-photo {
  width: 40rpx;
  height: 56rpx;
}

.four-thumb .mini-photo {
  width: 36rpx;
  height: 28rpx;
}

.eight-thumb .mini-photo {
  width: 20rpx;
  height: 20rpx;
}

/* 水印提示 */
.watermark-tip {
  background: #FFF8E1;
  border: 1rpx solid #FFE082;
}

.tip-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tip-icon {
  font-size: 36rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #F57C00;
  flex: 1;
}

.tip-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-btn {
  font-size: 28rpx !important;
  padding: 18rpx 0 !important;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 30rpx;
}

.action-btn {
  font-size: 30rpx !important;
  padding: 24rpx 0 !important;
}
